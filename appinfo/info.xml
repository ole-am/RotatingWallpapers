<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>rotatingwallpapers</id>
	<name>Rotating Wallpapers</name>
	<summary>An easy-to-use Nextcloud customization app that adds rotating background wallpapers.</summary>
	<description><![CDATA[
🖼️ Create a more dynamic and visually engaging user experience with rotating background wallpapers. Upload and manage multiple images through the admin settings, define a custom rotation interval, and optionally set a dedicated wallpaper for guests and the login page.

> Please note that uploaded images may be publicly accessible via the web.
	]]></description>
	<version>1.0.0</version>
    <licence>agpl</licence>
	<author mail="development@oa-web.de">Ole Am</author>
	<namespace>RotatingWallpapers</namespace>
	<category>customization</category>
    <website>https://github.com/ole-am/RotatingWallpapers</website>
    <bugs>https://github.com/ole-am/RotatingWallpapers/issues</bugs>
	<screenshot small-thumbnail="https://raw.githubusercontent.com/ole-am/RotatingWallpapers/refs/heads/main/screenshot-admin-thumbnail.png">https://raw.githubusercontent.com/ole-am/RotatingWallpapers/refs/heads/main/screenshot-admin-1.png</screenshot>
    <screenshot>https://raw.githubusercontent.com/ole-am/RotatingWallpapers/refs/heads/main/screenshot-admin-2.png</screenshot>
	<dependencies>
		<nextcloud min-version="31" max-version="33"/>
	</dependencies>
	<repair-steps>
		<install>
			<step>OCA\RotatingWallpapers\Repair\CreateAppData</step>
		</install>
		<uninstall>
			<step>OCA\RotatingWallpapers\Repair\ClearAppData</step>
		</uninstall>
	</repair-steps>
	<settings>
		<admin>OCA\RotatingWallpapers\Settings\AdminSettings</admin>
		<admin-section>OCA\RotatingWallpapers\Settings\AdminSection</admin-section>
	</settings>
